# AnythingLLM environment variables
# Copy this file to docker/.env, fill in EVERY value, and keep it private.
# NEVER commit docker/.env to version control.
#
# Generate secure random values with:
#   python -c "import secrets; print(secrets.token_hex(32))"

# ── Authentication ──────────────────────────────────────────────────────────
# A long random string (≥ 20 chars) used to sign JWT tokens.
JWT_SECRET=CHANGE_ME_use_python_secrets_token_hex_32

# The API key that HeLLMholtz (and any other client) uses to authenticate
# against the AnythingLLM REST API.  Set this in the UI after first login,
# then copy the value here and also into your hellmholtz .env file as
# ANYTHINGLLM_API_KEY.
API_KEY=CHANGE_ME

# ── LLM Provider ───────────────────────────────────────────────────────────
# Supported: openai | anthropic | ollama | lmstudio | localai | …
LLM_PROVIDER=openai
# LLM_PROVIDER=ollama

# OpenAI
OPEN_AI_KEY=sk-CHANGE_ME
OPEN_MODEL_PREF=gpt-4o

# Ollama (only needed when LLM_PROVIDER=ollama)
# On Linux the host gateway is 172.17.0.1; on Windows/macOS use host.docker.internal.
# OLLAMA_BASE_PATH=http://172.17.0.1:11434
# OLLAMA_MODEL_PREF=llama3.1
# OLLAMA_MODEL_TOKEN_LIMIT=4096

# ── Embedding Engine ────────────────────────────────────────────────────────
# Supported: native | openai | ollama | …
EMBEDDING_ENGINE=native
# EMBEDDING_ENGINE=ollama
# EMBEDDING_BASE_PATH=http://172.17.0.1:11434
# EMBEDDING_MODEL_PREF=nomic-embed-text:latest
# EMBEDDING_MODEL_MAX_CHUNK_LENGTH=8192

# ── Storage ─────────────────────────────────────────────────────────────────
# Already set in docker-compose.yml; listed here for completeness.
# STORAGE_DIR=/app/server/storage
